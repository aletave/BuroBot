# Copia in `.env` in locale. Su Vercel: Impostazioni progetto → Variabili d’ambiente (stessi nomi).

# Obbligatorio: chat e caricamento PDF (chiave API Gemini)
GEMINI_API_KEY=

# Opzionale: cronologia chat (Supabase)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Opzionale: Dialogflow CX (primo messaggio); senza queste variabili resta solo Gemini
GCP_PROJECT_ID=
DIALOGFLOW_AGENT_ID=
DIALOGFLOW_LOCATION=europe-west1

# Opzionale: Vertex AI e grounding su `/api/chat-grounded`
GCP_REGION=europe-west1
# In locale: percorso al JSON del service account. In cloud: vedi README per service account / integrazione GCP
